{"aggregate_id": "01KXP76R20B7GDSGW5VFEK9TFG", "aggregate_type": "Mission", "event_id": "01KXP76TD9VM6FCC37D56GXNFZ", "event_type": "MissionCreated", "payload": {"created_at": "2026-07-16T19:42:08.449434+00:00", "friendly_name": "Guide Site, Book, and LLM Bootstrap", "mission_id": "01KXP76R20B7GDSGW5VFEK9TFG", "mission_number": null, "mission_slug": "guide-site-build-01KXP76R", "mission_type": "software-dev", "purpose_context": "The guide's text is finished but reaches nobody: it exists only as markdown in a git repo. This mission builds the pipeline that turns that markdown into the four surfaces the project needs - a readable website for creators evaluating whether to join, a printable book for people who read on paper, machine-readable sources so an LLM can consume the guide directly, and the pack branch creators attach to their own projects as a submodule. All four are generated from the same bytes so they can never disagree. The single most important outcome is behavioural: a creator should be able to hand any LLM one URL and have it set up their workspace and start the interview.", "purpose_tldr": "Publish the Dungeon Master's Guide as an attractive website, a printable book, and a one-URL bootstrap any LLM can follow to start building.", "target_branch": "feat/guide-site-build", "wp_count": 0}, "project_slug": "dungeon-masters-guide", "project_uuid": "fa6e8103-68a1-4ba1-9900-87227113af47", "schema_version": "5.0.0", "timestamp": "2026-07-16T19:42:10.857651+00:00"}
